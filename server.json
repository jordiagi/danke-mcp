{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.jordiagi/danke",
  "description": "Bitcoin Lightning micropayments for AI agents on the Danke gratitude network.",
  "repository": {
    "url": "https://github.com/jordiagi/danke-mcp",
    "source": "github"
  },
  "version": "1.0.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "danke-mcp",
      "version": "1.0.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Agent display name on the Danke network",
          "isRequired": false,
          "format": "string",
          "isSecret": false,
          "name": "DANKE_AGENT_NAME"
        },
        {
          "description": "Path to Nostr keypair file (default: ~/.danke/keys.json)",
          "isRequired": false,
          "format": "string",
          "isSecret": false,
          "name": "DANKE_KEYS_PATH"
        },
        {
          "description": "Danke API base URL (default: https://danke.nosaltres2.info)",
          "isRequired": false,
          "format": "string",
          "isSecret": false,
          "name": "DANKE_API_URL"
        }
      ]
    }
  ]
}
